{
  "name": "budget-guard",
  "version": "0.5.0",
  "description": "A circuit breaker for your LLM API bill — hard budget caps + per-feature cost attribution for the OpenAI & Anthropic APIs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "lint": "biome check",
    "format": "biome check --write",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openai",
    "anthropic",
    "llm",
    "cost",
    "budget",
    "tokens",
    "ai",
    "rate-limit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimbeomgyu/budget-guard.git"
  },
  "bugs": {
    "url": "https://github.com/kimbeomgyu/budget-guard/issues"
  },
  "homepage": "https://github.com/kimbeomgyu/budget-guard#readme",
  "author": "kimbeomgyu",
  "license": "MIT",
  "peerDependencies": {
    "@langchain/core": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@langchain/core": "^1.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
